# Copia este archivo a .env y pega tu token de Hugging Face.
# El repo del Modelo 1 (Ethermed/formulary-relevance-classifier) es PRIVADO,
# así que necesitas un token con acceso a la org Ethermed.

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat de corrección (Modelo 2): pon UNA según tu token
GEMINI_API_KEY=AIza...tu_clave_aqui
GEMINI_CHAT_MODEL=gemini-2.5-flash
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_PROVIDER=gemini

# Opcionales (descomenta para overridear):
# RELEVANCE_MODEL=Ethermed/formulary-relevance-classifier
# RELEVANCE_MODEL=C:/ruta/a/un/formulary_classifier   # o un modelo local
# DEVICE=cpu
# RELEVANCE_THRESHOLD=0.5
# THUMB_DPI=72
# FULL_DPI=140
